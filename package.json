{
  "dependencies": {
    "ink": "^7.1.0",
    "meow": "^14.1.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@sindresorhus/tsconfig": "^8.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "ava": "^8.0.1",
    "ink-testing-library": "^4.0.0",
    "lefthook": "^2.1.10",
    "taze": "^19.14.1",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "ultracite": "7.8.3"
  },
  "name": "@ikrammaulana/kfwd",
  "description": "CLI to manage named kubectl port-forward rules as background processes",
  "scripts": {
    "start": "tsx src/cli.tsx",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "dev": "tsc --watch",
    "check": "ultracite check",
    "check-types": "tsc --noEmit",
    "fix": "ultracite fix",
    "test": "ava",
    "deps:check": "taze",
    "deps:update": "taze -w && pnpm install",
    "deps:clean": "taze -w && pnpm clean && pnpm install && pnpm audit --fix override"
  },
  "type": "module",
  "version": "0.1.2",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ikram-Maulana/kfwd.git"
  },
  "bin": {
    "kfwd": "dist/src/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist/src"
  ],
  "ava": {
    "files": [
      "test/**/*"
    ],
    "workerThreads": false,
    "extensions": [
      "ts",
      "tsx"
    ],
    "nodeArguments": [
      "--import=tsx"
    ]
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
