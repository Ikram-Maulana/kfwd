{
  "dependencies": {
    "ink": "^7.1.0",
    "meow": "^14.1.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@sindresorhus/tsconfig": "^8.1.0",
    "@types/react": "^19.2.17",
    "ava": "^8.0.1",
    "chalk": "^5.6.2",
    "ink-testing-library": "^4.0.0",
    "lefthook": "^2.1.9",
    "taze": "^19.14.1",
    "tsimp": "^2.0.12",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3"
  },
  "name": "kfwd",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "ultracite check",
    "check-types": "tsc --noEmit",
    "fix": "ultracite fix",
    "test": "ava",
    "deps:check": "taze",
    "deps:update": "taze -w && pnpm install",
    "deps:clean": "taze -w && pnpm clean && pnpm install && pnpm audit --fix override"
  },
  "type": "module",
  "version": "0.0.0",
  "license": "MIT",
  "bin": "dist/cli.js",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "ava": {
    "extensions": [
      "ts",
      "tsx"
    ],
    "nodeArguments": [
      "--import=tsimp"
    ]
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
